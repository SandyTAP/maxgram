APP_NAME=MaxGram Telegram OTP
APP_ENV=local
DEBUG=false
SECRET_KEY=change-this-secret-with-openssl-rand-hex-32
JWT_SECRET_KEY=change-this-jwt-secret-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_SECURE=false
COOKIE_DOMAIN=
SITE_URL=http://localhost

POSTGRES_DB=maxgram
POSTGRES_USER=maxgram
POSTGRES_PASSWORD=maxgram_password
DATABASE_URL=postgresql+asyncpg://maxgram:maxgram_password@postgres:5432/maxgram
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

TELEGRAM_BOT_TOKEN=123456:replace-with-real-token
TELEGRAM_WEBHOOK_SECRET=
OTP_TTL_SECONDS=120
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_VERIFY_LIMIT=5
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
NUMBER_LEASE_MINUTES=15

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-admin-password
